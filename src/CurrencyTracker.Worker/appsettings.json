{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Frankfurter": {
    "BaseUrl": "https://api.frankfurter.dev",
    "Timeout": "00:00:10",
    "UserAgent": "CurrencyTracker/1.0 (+https://github.com/mpcs2013/currency-tracker)"
  },
  "Worker": {
    "IngestSchedule": "0 0 6 * * ?",
    "IngestBases": [ "USD", "EUR", "CHF" ]
  }
}
